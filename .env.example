APP_MODE=demo
VITE_APP_MODE=demo

# Local application placeholders
PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://user:password@localhost:5432/demo
POSTGRES_PASSWORD=replace-with-local-database-password
ACTION_LOG_FILE=.data/permission-action-logs.json
SETUP_HANDOFF_TOKEN=replace-with-local-setup-handoff-token

# Microsoft Graph / Entra bootstrap placeholders
MICROSOFT_BOOTSTRAP_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_BOOTSTRAP_CLIENT_SECRET=replace-with-bootstrap-client-secret
MICROSOFT_BOOTSTRAP_TENANT_ID=organizations
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/microsoft/connect/callback
MICROSOFT_GRAPH_RESOURCE_APP_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_BOOTSTRAP_SCOPES=openid,profile,offline_access,.default
MICROSOFT_CONNECTOR_PERMISSIONS=Directory.Read.All,Group.Read.All,User.Read.All,Sites.ReadWrite.All,Files.ReadWrite.All
MICROSOFT_SECRET_ENCRYPTION_KEY=replace-with-long-random-local-encryption-key
MICROSOFT_ALLOW_DESTRUCTIVE_DISCONNECT=false

# Optional standalone setup assistant placeholders
SETUP_ASSISTANT_CLIENT_ID=00000000-0000-0000-0000-000000000000
SETUP_ASSISTANT_CLIENT_SECRET=replace-with-setup-assistant-client-secret
SETUP_ASSISTANT_REDIRECT_URI=http://localhost:4100/api/auth/callback
SETUP_ASSISTANT_PORT=4100

# Optional Power Platform placeholders
POWER_PLATFORM_ENVIRONMENTS_JSON=[]
POWER_PLATFORM_ACCESS_TOKEN=replace-with-dataverse-access-token

# Optional Fabric placeholders
FABRIC_IQ_ENABLED=false
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_ONTOLOGY_ID=00000000-0000-0000-0000-000000000000
FABRIC_LAKEHOUSE_ID=00000000-0000-0000-0000-000000000000
FABRIC_API_BASE_URL=https://api.fabric.microsoft.com
